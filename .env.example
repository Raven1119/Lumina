# Lumina Cold Draft MVP configuration.
# Copy to .env.local. Never commit real credentials.

# Default mode is mock. Change to real only with all MiniMax settings below.
LUMINA_MODEL_MODE=mock
LUMINA_MODEL_PROVIDER=minimax-anthropic
LUMINA_MODEL_API_KEY=replace-with-local-secret
LUMINA_MODEL_BASE_URL=https://provider.example/anthropic
LUMINA_MODEL_NAME=replace-with-model-name

# Hot Draft path. Cold Draft and compaction state use the same directory.
LUMINA_DRAFT_STORE_PATH=data/draft/hot_drafts.jsonl
